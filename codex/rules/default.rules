# ported from claude-code permissions allowlist
prefix_rule(
    pattern=[
        [
            "cat",
            "ls",
            "find",
            "which",
            "head",
            "tail",
            "wc",
            "file",
            "stat",
            "tree",
            "pwd",
            "echo",
            "grep",
            "rg",
            "fd",
            "basename",
            "dirname",
            "realpath",
            "readlink",
            "cd",
            "printf",
            "jq",
            "yq",
            "diff",
            "sort",
            "uniq",
            "cut",
            "tr",
            "awk",
            "sed",
            "env",
            "printenv",
            "whoami",
            "hostname",
            "date",
            "uname",
            "id",
            "type",
            "command",
            "test",
            "[",
            "du",
            "df",
            "ps",
            "pgrep",
            "lsof",
            "xattr",
            "mdls",
            "mdfind",
        ],
    ],
    decision="allow",
)

# mirror current claude settings.json command-family breadth
prefix_rule(pattern=["curl"], decision="allow")
prefix_rule(pattern=["claude"], decision="allow")
prefix_rule(pattern=["gh"], decision="allow")
prefix_rule(pattern=["brew"], decision="allow")
prefix_rule(pattern=["git"], decision="allow")
prefix_rule(pattern=["npm"], decision="allow")
prefix_rule(pattern=["bun"], decision="allow")
prefix_rule(pattern=["node"], decision="allow")
prefix_rule(pattern=["python"], decision="allow")
prefix_rule(pattern=["python3"], decision="allow")
prefix_rule(pattern=["pip"], decision="allow")
prefix_rule(pattern=["pip3"], decision="allow")
prefix_rule(pattern=["uv"], decision="allow")
prefix_rule(pattern=["cargo"], decision="allow")
prefix_rule(pattern=["rustc"], decision="allow")
prefix_rule(pattern=["go"], decision="allow")
prefix_rule(pattern=["docker"], decision="allow")

prefix_rule(
    pattern=[
        "git",
        [
            "status",
            "log",
            "diff",
            "show",
            "branch",
            "remote",
            "tag",
            "ls-files",
            "ls-tree",
            "cat-file",
            "rev-parse",
            "describe",
            "blame",
            "shortlog",
            "add",
            "commit",
        ],
    ],
    decision="allow",
)

prefix_rule(pattern=["git", "stash", "list"], decision="allow")
prefix_rule(pattern=["git", "config", "--get"], decision="allow")

prefix_rule(
    pattern=["npm", ["list", "ls", "view", "info", "outdated", "--version"]],
    decision="allow",
)

prefix_rule(pattern=["bun", "--version"], decision="allow")
prefix_rule(pattern=["node", "--version"], decision="allow")
prefix_rule(pattern=["python", "--version"], decision="allow")
prefix_rule(pattern=["python3", "--version"], decision="allow")
prefix_rule(pattern=["uv", "--version"], decision="allow")
prefix_rule(pattern=["uv", "pip", ["list", "show"]], decision="allow")
prefix_rule(pattern=["cargo", ["--version", "tree"]], decision="allow")
prefix_rule(pattern=["rustc", "--version"], decision="allow")
prefix_rule(pattern=["go", ["version", "list"]], decision="allow")

prefix_rule(pattern=["git", "add", "app/page.tsx"], decision="allow")

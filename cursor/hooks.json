{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "hooks/expose-worktrees.sh",
        "timeout": 30
      }
    ],
    "afterFileEdit": [
      {
        "command": "hooks/post-edit-format.sh",
        "matcher": "^Write$",
        "timeout": 120
      }
    ],
    "stop": [
      {
        "command": "hooks/sound.sh Glass",
        "timeout": 5
      }
    ]
  }
}
